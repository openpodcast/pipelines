# Open Podcast API
OPENPODCAST_API_ENDPOINT=https://api.openpodcast.dev
OPENPODCAST_API_TOKEN=<your_token>

# Spotify session cookies
# How to obtain: log in to https://creators.spotify.com, open DevTools ->
# Application -> Cookies -> https://accounts.spotify.com, copy sp_dc and sp_key.
SPOTIFY_SP_DC=<your_sp_dc>
SPOTIFY_SP_KEY=<your_sp_key>

# Optional
# DATE_RANGE_WINDOW=WINDOW_LAST_SEVEN_DAYS
# NUM_WORKERS=1
# TASK_DELAY=1.0
# STORE_DATA=false