OPENPODCAST_API_ENDPOINT=https://api.openpodcast.dev
OPENPODCAST_API_TOKEN=<OPENPODCAST_API_TOKEN>

# Spotify Creators GraphQL authentication cookies
SPOTIFY_SP_DC=<SPOTIFY_SP_DC>
SPOTIFY_SP_KEY=<SPOTIFY_SP_KEY>

# Optional: Spotify show URI (resolved automatically if omitted)
# SPOTIFY_SHOW_URI=spotify:show:abc123

# Optional: legacy station ID (resolved automatically if omitted)
# SPOTIFY_STATION_ID=
# PODCAST_ID=

# Optional explicit date range for analytics queries.
# Defaults match the spotify connector behavior:
#   START_DATE = today - 3 days
#   END_DATE   = today - 1 day
# START_DATE=2026-03-01
# END_DATE=2026-03-31
